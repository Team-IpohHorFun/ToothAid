# Server port (hosting platforms often set PORT automatically)
PORT=3001

# MongoDB: use Atlas URI in production (e.g. mongodb+srv://user:pass@cluster.mongodb.net/toothaid)
MONGODB_URI=mongodb://localhost:27017/toothaid

# Change in production
JWT_SECRET=your-secret-key-change-in-production
NODE_ENV=development

# Optional: restrict CORS to your frontend URL(s), comma-separated (e.g. https://your-app.netlify.app)
# If unset, all origins are allowed.
# FRONTEND_ORIGIN=
